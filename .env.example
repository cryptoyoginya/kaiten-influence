# Supabase — скопируй в .env.local и подставь значения из дашборда проекта
# Project Settings → API

# URL проекта (вида https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Публичный anon-ключ (можно отдавать в браузер)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Секретный service_role-ключ — ТОЛЬКО для скриптов миграции (supabase/seed.mjs).
# Никогда не коммитить и не отдавать в браузер.
SUPABASE_SERVICE_ROLE_KEY=
